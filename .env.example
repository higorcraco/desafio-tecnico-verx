# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=task_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_EXP_MINUTES=30

# CORS – origens permitidas separadas por vírgula (inclua a URL da API para o Swagger funcionar)
CORS_ALLOWED_ORIGINS=https://meuapp.com,https://admin.meuapp.com,https://api.meuapp.com
